#!/bin/sh
# Maven Wrapper

export JAVA_HOME="${JAVA_HOME:-/c/java/jdk-17.0.15}"
export PATH="$JAVA_HOME/bin:$PATH"

# Determine Maven Wrapper dir
PRG="$0"
while [ -h "$PRG" ]; do
  ls=$(ls -ld "$PRG")
  link=$(expr "$ls" : '.*-> \(.*\)$')
  if expr "$link" : '/.*' > /dev/null; then
    PRG="$link"
  else
    PRG=$(dirname "$PRG")/"$link"
  fi
done
SAVED="$(pwd)"
cd "$(dirname "$PRG")/" >/dev/null
APP_HOME="$(pwd -P)"
cd "$SAVED" >/dev/null

# Wrapper config
MAVEN_WRAPPER_JAR="${APP_HOME}/.mvn/wrapper/maven-wrapper.jar"
MAVEN_CONFIG="$HOME/.m2"

# Check if wrapper jar exists
if [ ! -f "$MAVEN_WRAPPER_JAR" ]; then
  echo "Maven Wrapper JAR not found: $MAVEN_WRAPPER_JAR"
  exit 1
fi

exec "$JAVA_HOME/bin/java" \
  -classpath "$MAVEN_WRAPPER_JAR" \
  -Dmaven.multiModuleProjectDirectory="$APP_HOME" \
  -Dmaven.wrapper.properties="${APP_HOME}/.mvn/wrapper/maven-wrapper.properties" \
  org.apache.maven.wrapper.MavenWrapperMain "$@"
